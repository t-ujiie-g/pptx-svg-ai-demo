# ========================================
# Gemini バックエンド選択
# ========================================
# Vertex AI を使う場合: TRUE（GOOGLE_CLOUD_PROJECT を設定、gcloud auth application-default login 済みであること）
# Gemini API (AI Studio) を使う場合: FALSE（GOOGLE_API_KEY を設定）
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Gemini API (AI Studio) を使う場合 ---
# https://aistudio.google.com/app/apikey で取得
GOOGLE_API_KEY=your-gemini-api-key

# --- Vertex AI を使う場合 ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# ========================================
# Backend
# ========================================
# エージェントで使用するモデル
GENAI_MODEL=gemini-3-flash-preview
PPTX_AGENT_MODEL=gemini-3.1-pro-preview
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
# CORS許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# ========================================
# Frontend
# ========================================
VITE_API_BASE_URL=http://localhost:8000
